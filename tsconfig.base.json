{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@mailverwerkings/email-domain": ["libs/email/domain/src/index.ts"],
      "@mailverwerkings/email-application": ["libs/email/application/src/index.ts"],
      "@mailverwerkings/email-infrastructure": ["libs/email/infrastructure/src/index.ts"],
      "@mailverwerkings/ai-domain": ["libs/ai/domain/src/index.ts"],
      "@mailverwerkings/ai-application": ["libs/ai/application/src/index.ts"],
      "@mailverwerkings/ai-infrastructure": ["libs/ai/infrastructure/src/index.ts"],
      "@mailverwerkings/candidate-domain": ["libs/candidate/domain/src/index.ts"],
      "@mailverwerkings/candidate-application": ["libs/candidate/application/src/index.ts"],
      "@mailverwerkings/candidate-infrastructure": ["libs/candidate/infrastructure/src/index.ts"],
      "@mailverwerkings/shared-types": ["libs/shared/types/src/index.ts"],
      "@mailverwerkings/shared-utils": ["libs/shared/utils/src/index.ts"]
    }
  }
}
